CLOUDFLARE_DATABASE_ID="[CLOUDFLARE_DATABASE_ID]"

# Cloudflare dashboard: Workers & Pages -> Overview -> copy Account ID
CLOUDFLARE_ACCOUNT_ID="[CLOUDFLARE_ACCOUNT_ID]"
# Cloudflare dashboard: My profile -> API Tokens
CLOUDFLARE_D1_TOKEN="[CLOUDFLARE_D1_TOKEN]"

# Aliyun CAPTCHA 2.0 (prefix = SceneId from console)
CAPTCHA_PREFIX="[CAPTCHA_PREFIX]"

# Authjs Secret
AUTH_SECRET="[AUTH_SECRET]"

# Aliyun SMS
ALIBABA_CLOUD_ACCESS_KEY_ID="[ALIBABA_CLOUD_ACCESS_KEY_ID]"
ALIBABA_CLOUD_ACCESS_KEY_SECRET="[ALIBABA_CLOUD_ACCESS_KEY_SECRET]"

# Dev mode: set a fixed SMS verification code to bypass Aliyun SMS sending (e.g. "666666")
# When set, all SMS codes will use this value — no real SMS is sent.
# Leave empty or remove in production.
# DEV_SMS_CODE="666666"

# WeChat Open Platform (PC 扫码登录) - open.weixin.qq.com
WECHAT_OPEN_APP_ID="[WECHAT_OPEN_APP_ID]"
WECHAT_OPEN_APP_SECRET="[WECHAT_OPEN_APP_SECRET]"

# WeChat MP Platform (微信内网页授权) - mp.weixin.qq.com
WECHAT_MP_APP_ID="[WECHAT_MP_APP_ID]"
WECHAT_MP_APP_SECRET="[WECHAT_MP_APP_SECRET]"

# GSZ (全国日麻公式站) API Token
GSZ_TOKEN="[GSZ_TOKEN]"
