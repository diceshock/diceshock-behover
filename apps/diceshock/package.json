{
  "name": "diceshock",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "deploy:update": "$npm_execpath run build && npx wrangler versions upload",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "drizzle": "drizzle-kit",
    "helper": "npm run start --workspace=scripts --",
    "codegen": "graphql-codegen --config codegen.ts",
    "seed:e2e": "tsx scripts/seed-e2e.ts",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:ui": "playwright test --config playwright.config.ts --ui",
    "test:e2e:report": "playwright show-report ./e2e/artifacts/html-report"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "0.2.16",
    "@ai-sdk/openai": "^1.3.24",
    "@ai-sdk/react": "^1.2.12",
    "@apollo/client": "~3.13.9",
    "@cloudflare/puppeteer": "^1.1.0",
    "@hono/auth-js": "^1.1.1",
    "@phosphor-icons/react": "^2.1.10",
    "@react-spring/web": "^10.0.3",
    "@tanstack/react-router": "^1.167.5",
    "@tanstack/react-router-devtools": "^1.166.9",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-image": "^3.21.0",
    "@tiptap/extension-link": "^3.21.0",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/extension-underline": "^3.21.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "@types/qrcode": "^1.5.6",
    "@xmldom/xmldom": "^0.9.10",
    "ai": "^4.3.19",
    "chinese-days": "^1.5.7",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "hono": "^4.12.8",
    "i18next": "^25.8.20",
    "jotai": "^2.18.1",
    "js-base64": "^3.7.8",
    "js-cookie": "^3.0.5",
    "lodash": "^4.17.23",
    "lz-string": "^1.5.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.7",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-json-view-lite": "^2.5.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "rrule": "^2.8.1",
    "tiptap-markdown": "^0.9.0",
    "zdog": "^1.1.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/import-types-preset": "^4.0.1",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-operations": "^6.0.4",
    "@graphql-codegen/typescript-react-apollo": "^4.4.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-plugin": "^1.166.14",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.9",
    "@types/zdog": "^1.1.7",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "daisyui": "^5.5.19",
    "drizzle-graphql": "0.8.5",
    "graphql": "16.13.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vite-plugin-svgr": "^4.5.0",
    "vite-ssr-components": "^0.5.2"
  }
}
