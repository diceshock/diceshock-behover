    "i18next": "^25.8.20",
    "jotai": "^2.18.1",
    "js-cookie": "^3.0.5",
    "lodash": "^4.17.23",
    "lz-string": "^1.5.0",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-json-view-lite": "^2.5.0",
    "zdog": "^1.1.3"
