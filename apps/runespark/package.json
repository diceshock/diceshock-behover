{
  "name": "runespark",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "deploy:update": "$npm_execpath run build && npx wrangler versions upload",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "drizzle": "drizzle-kit",
    "migrations:subscriptions": "wrangler d1 migrations apply subscriptions",
    "helper": "npm run start --workspace=scripts --"
  },
  "dependencies": {
